      "default": "Stink Safe products are storage accessories intended for use with legal products only, in accordance with local law. You must be 18 or over to purchase."
    },
    {
      "type": "header",
      "content": "Legal page links"
    },
    {
      "type": "url",
      "id": "privacy_url",
      "label": "Privacy policy URL"
    },
    {
      "type": "url",
      "id": "cookies_url",
      "label": "Cookie policy URL"
    },
    {
      "type": "url",
      "id": "terms_url",
      "label": "Terms of service URL"
    }
  ]
}
{% endschema %}
