<footer class="site-footer full-width">

  {%- comment -%} Halftone dot texture {%- endcomment -%}
  <div class="site-footer__dots" aria-hidden="true"></div>

  <div class="site-footer__inner">

    {%- comment -%}
      Logo — uses the asset file by default; section.settings.logo overrides it
      when a merchant uploads their own via the theme editor.
    {%- endcomment -%}
    {%- if section.settings.logo != blank -%}
      <a href="{{ routes.root_url }}" class="site-footer__logo-link">
        {{- section.settings.logo
          | image_url: width: 240
          | image_tag:
            alt: shop.name,
            loading: 'lazy',
            class: 'site-footer__logo'
        -}}
      </a>
    {%- else -%}
      <a href="{{ routes.root_url }}" class="site-footer__logo-link">
        <img
          src="{{ 'stink-safe-logo.png' | asset_url }}"
          alt="{{ shop.name | escape }}"
          class="site-footer__logo"
          loading="lazy"
          width="160"
          height="42"
        >
      </a>
    {%- endif -%}

    {%- comment -%} Tagline {%- endcomment -%}
    {%- if section.settings.tagline != blank -%}
      <p class="site-footer__tagline">{{- section.settings.tagline | escape -}}</p>
    {%- endif -%}

    {%- comment -%} Three link columns {%- endcomment -%}
    <div class="site-footer__columns">

      <div class="site-footer__column">
        {%- if section.settings.shop_heading != blank -%}
          <p class="site-footer__col-heading">{{- section.settings.shop_heading | escape -}}</p>
        {%- endif -%}
        {%- for link in section.settings.shop_menu.links -%}
          <a href="{{ link.url }}" class="site-footer__link">{{- link.title -}}</a>
        {%- endfor -%}
      </div>

      <div class="site-footer__column">
        {%- if section.settings.help_heading != blank -%}
          <p class="site-footer__col-heading">{{- section.settings.help_heading | escape -}}</p>
        {%- endif -%}
        {%- for link in section.settings.help_menu.links -%}
          <a href="{{ link.url }}" class="site-footer__link">{{- link.title -}}</a>
        {%- endfor -%}
      </div>

      <div class="site-footer__column">
        {%- if section.settings.company_heading != blank -%}
          <p class="site-footer__col-heading">{{- section.settings.company_heading | escape -}}</p>
        {%- endif -%}
        {%- for link in section.settings.company_menu.links -%}
          <a href="{{ link.url }}" class="site-footer__link">{{- link.title -}}</a>
        {%- endfor -%}
      </div>

    </div>

    {%- comment -%} Social icon row {%- endcomment -%}
    <div class="site-footer__socials">

      {%- if section.settings.instagram_url != blank -%}
        <a href="{{ section.settings.instagram_url }}" class="site-footer__social" aria-label="Instagram" target="_blank" rel="noopener noreferrer">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.85" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="4" y="4" width="16" height="16" rx="5"/>
            <circle cx="12" cy="12" r="4"/>
            <circle cx="17" cy="7" r="1.1" fill="currentColor" stroke="none"/>
          </svg>
        </a>
      {%- endif -%}

      {%- if section.settings.tiktok_url != blank -%}
        <a href="{{ section.settings.tiktok_url }}" class="site-footer__social" aria-label="TikTok" target="_blank" rel="noopener noreferrer">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.85" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M9 9.5v6a2.5 2.5 0 1 1-2.5-2.5"/>
            <path d="M9 5c.4 2.3 1.9 3.8 4.2 4v2.7C11 11.6 9.7 10.8 9 9.7"/>
          </svg>
        </a>
      {%- endif -%}

      {%- if section.settings.telegram_url != blank -%}
        <a href="{{ section.settings.telegram_url }}" class="site-footer__social" aria-label="Telegram" target="_blank" rel="noopener noreferrer">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.85" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="m22 3-9.5 9.5"/>
            <path d="M22 3 15 21l-3.5-7.5L4 10z"/>
          </svg>
        </a>
      {%- endif -%}

    </div>

    {%- comment -%} Payment icons {%- endcomment -%}
    {%- if section.settings.show_payment_icons and shop.enabled_payment_types != empty -%}
      <div class="site-footer__payments" aria-label="{{ 'footer.payment_methods' | t }}">
        {%- for type in shop.enabled_payment_types -%}
          <span class="site-footer__payment-pill">
            {{- type | payment_type_svg_tag -}}
          </span>
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- comment -%} Legal strip {%- endcomment -%}
    <div class="site-footer__legal">
      <p>
        {%- if section.settings.legal_text != blank -%}
          {{- section.settings.legal_text | escape -}}&ensp;&middot;&ensp;
        {%- endif -%}
        &copy;&nbsp;{{ 'now' | date: '%Y' }}&nbsp;{{ shop.name | escape }}.&nbsp;{{ 'footer.all_rights' | t }}
      </p>
    </div>

  </div>
</footer>

{% stylesheet %}
  /* --------------------------------------------------------
     Footer shell — Ink canvas, full bleed
  -------------------------------------------------------- */
  .site-footer {
    background: var(--color-ink);
    color: var(--color-white);
    position: relative;
    overflow: hidden;
  }

  /* Halftone dots — from wireframe: rgba(255,255,255,.06), 1.4px on 13px grid */
  .site-footer__dots {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(rgba(255, 255, 255, 0.06) 1.4px, transparent 1.6px);
    background-size: 13px 13px;
    pointer-events: none;
  }

  /* Inner content above the texture — padding matches wireframe: 30px 18px 20px */
  .site-footer__inner {
    position: relative;
    padding: 30px 18px 20px;
    display: flex;
    flex-direction: column;
  }

  /* --------------------------------------------------------
     Logo
  -------------------------------------------------------- */
  .site-footer__logo-link {
    display: inline-block;
    margin-bottom: 12px;
    text-decoration: none;
  }

  .site-footer__logo {
    height: 42px;
    width: auto;
    display: block;
  }

  /* Fallback shop name text when no logo asset is set */
  .site-footer__shop-name {
    display: inline-block;
    font-family: var(--font-display);
    font-size: 20px;
    font-weight: 800;
    color: var(--color-white);
    letter-spacing: -0.02em;
    margin-bottom: 12px;
  }

  /* --------------------------------------------------------
     Tagline
  -------------------------------------------------------- */
  .site-footer__tagline {
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 400;
    line-height: 1.55;
    color: var(--color-ink-subtle);
    max-width: 236px;
    margin-bottom: 24px;
  }

  /* --------------------------------------------------------
     Link columns — wireframe: 3-col grid, 14px gap
  -------------------------------------------------------- */
  .site-footer__columns {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 14px;
    margin-bottom: 24px;
  }

  .site-footer__col-heading {
    font-family: var(--font-label);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-white);
    margin-bottom: 12px;
  }

  .site-footer__link {
    display: block;
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 400;
    line-height: 1;
    color: var(--color-ink-subtle);
    text-decoration: none;
    margin-bottom: 10px;
    transition: color 120ms;
  }
  .site-footer__link:last-child { margin-bottom: 0; }
  .site-footer__link:hover { color: var(--color-white); }

  /* --------------------------------------------------------
     Social icons — wireframe: 34×34px, radius 10px, bg #11182B
  -------------------------------------------------------- */
  .site-footer__socials {
    display: flex;
    gap: 8px;
    margin-bottom: 18px;
  }

  .site-footer__social {
    width: 34px;
    height: 34px;
    border-radius: 10px;
    background: var(--color-surface-dark);
    color: var(--color-ink-subtle);
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    flex: 0 0 auto;
    transition: color 120ms, background 120ms;
  }
  .site-footer__social svg {
    width: 17px;
    height: 17px;
    flex: 0 0 auto;
  }
  .site-footer__social:hover {
    color: var(--color-white);
    background: #1e2a42;
  }

  /* --------------------------------------------------------
     Payment icons — each in a white rounded pill
  -------------------------------------------------------- */
  .site-footer__payments {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-bottom: 18px;
    align-items: center;
  }

  /* Pill wrapper — white bg + rounded corners matching wireframe */
  .site-footer__payment-pill {
    background: var(--color-white);
    border-radius: 5px;
    padding: 4px 7px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 28px;
  }

  /* Shopify's payment_type_svg_tag outputs an <svg> — constrain it */
  .site-footer__payment-pill svg {
    height: 18px;
    width: auto;
    display: block;
  }

  /* --------------------------------------------------------
     Legal strip — wireframe: border-top #1B2336, color #7C8597
  -------------------------------------------------------- */
  .site-footer__legal {
    border-top: 1px solid var(--color-border-dark);
    padding-top: 14px;
  }

  .site-footer__legal p {
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 400;
    line-height: 1.6;
    color: var(--color-ink-faint);
  }

  /* --------------------------------------------------------
     Desktop enhancements (768px+)
     The wireframe is 390px mobile — these go beyond the spec
     but maintain the brand feel at wider viewports.
  -------------------------------------------------------- */
  @media (min-width: 768px) {
    .site-footer__inner {
      padding: 40px 32px 28px;
    }
  }

  @media (min-width: 1024px) {
    .site-footer__inner {
      display: grid;
      grid-template-columns: 220px 1fr;
      grid-template-rows: auto auto auto auto auto;
      column-gap: 64px;
      padding: 48px 48px 36px;
    }

    /* Brand column spans full height on the left */
    .site-footer__logo-link {
      grid-column: 1;
      grid-row: 1;
      margin-bottom: 0;
      align-self: start;
    }

    .site-footer__tagline {
      grid-column: 1;
      grid-row: 2;
      max-width: none;
      margin-bottom: 0;
    }

    /* Right side: columns, socials, payments, legal stack */
    .site-footer__columns {
      grid-column: 2;
      grid-row: 1 / 3;
      gap: 24px;
      margin-bottom: 0;
      align-self: start;
    }

    .site-footer__socials {
      grid-column: 2;
      grid-row: 3;
      margin-bottom: 0;
      margin-top: 28px;
    }

    .site-footer__payments {
      grid-column: 2;
      grid-row: 4;
      margin-bottom: 0;
      margin-top: 16px;
    }

    .site-footer__legal {
      grid-column: 1 / -1;
      grid-row: 5;
      margin-top: 28px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.footer",
  "settings": [
    {
      "type": "header",
      "content": "t:general.brand"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "t:labels.logo"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "t:labels.tagline",
      "default": "Premium smell-proof storage — collectible art, built to last."
    },
    {
      "type": "header",
      "content": "t:general.navigation"
    },
    {
      "type": "text",
      "id": "shop_heading",
      "label": "t:labels.shop_heading",
      "default": "Shop"
    },
    {
      "type": "link_list",
      "id": "shop_menu",
      "label": "t:labels.shop_menu"
    },
    {
      "type": "text",
      "id": "help_heading",
      "label": "t:labels.help_heading",
      "default": "Help"
    },
    {
      "type": "link_list",
      "id": "help_menu",
      "label": "t:labels.help_menu"
    },
    {
      "type": "text",
      "id": "company_heading",
      "label": "t:labels.company_heading",
      "default": "Company"
    },
    {
      "type": "link_list",
      "id": "company_menu",
      "label": "t:labels.company_menu"
    },
    {
      "type": "header",
      "content": "t:general.social"
    },
    {
      "type": "url",
      "id": "instagram_url",
      "label": "t:labels.instagram_url"
    },
    {
      "type": "url",
      "id": "tiktok_url",
      "label": "t:labels.tiktok_url"
    },
    {
      "type": "url",
      "id": "telegram_url",
      "label": "t:labels.telegram_url"
    },
    {
      "type": "header",
      "content": "t:general.payment_legal"
    },
    {
      "type": "checkbox",
      "id": "show_payment_icons",
      "label": "t:labels.show_payment_icons",
      "default": true
    },
    {
      "type": "textarea",
      "id": "legal_text",
      "label": "t:labels.legal_text",
      "default": "For storage of legal goods only. Sold for lawful use in accordance with local law."
    }
  ]
}
{% endschema %}
