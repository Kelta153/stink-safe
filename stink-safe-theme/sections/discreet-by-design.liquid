<div class="discreet">
  <h2 class="discreet__heading">
    {{- section.settings.heading | default: 'Discreet by design' | escape -}}
  </h2>

  <div class="discreet__list">

    <div class="discreet__item">
      <span class="discreet__icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="#2463EB" stroke-width="1.85" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 3 5 6v6c0 4.2 3 6.9 7 8 4-1.1 7-3.8 7-8V6z"/>
        </svg>
      </span>
      <div>
        <p class="discreet__title">{{ 'sections.discreet.feature_1_title' | t }}</p>
        <p class="discreet__sub">{{ 'sections.discreet.feature_1_sub' | t }}</p>
      </div>
    </div>

    <div class="discreet__item">
      <span class="discreet__icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="#2463EB" stroke-width="1.85" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 8 12 3 3 8v8l9 5 9-5z"/>
          <path d="M3 8l9 5 9-5"/>
          <path d="M12 13v8"/>
        </svg>
      </span>
      <div>
        <p class="discreet__title">{{ 'sections.discreet.feature_2_title' | t }}</p>
        <p class="discreet__sub">{{ 'sections.discreet.feature_2_sub' | t }}</p>
      </div>
    </div>

    <div class="discreet__item">
      <span class="discreet__icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="#2463EB" stroke-width="1.85" stroke-linecap="round" stroke-linejoin="round">
          <rect x="5" y="11" width="14" height="9" rx="2"/>
          <path d="M8 11V8a4 4 0 0 1 8 0v3"/>
        </svg>
      </span>
      <div>
        <p class="discreet__title">{{ 'sections.discreet.feature_3_title' | t }}</p>
        <p class="discreet__sub">{{ 'sections.discreet.feature_3_sub' | t }}</p>
      </div>
    </div>

  </div>
</div>

{% stylesheet %}
  .discreet {
    padding: 16px 0 6px;
  }
  .discreet__heading {
    font-family: var(--font-display);
    font-size: 18px;
    font-weight: 800;
    line-height: 1.1;
    color: var(--color-ink);
    margin: 0 0 12px;
  }
  .discreet__list {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .discreet__item {
    display: flex;
    gap: 12px;
    align-items: center;
    border: 1px solid var(--color-hairline);
    border-radius: 14px;
    padding: 13px;
  }
  .discreet__icon {
    width: 34px;
    height: 34px;
    border-radius: 9px;
    background: var(--color-mist);
    flex: 0 0 auto;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .discreet__icon svg {
    width: 18px;
    height: 18px;
  }
  .discreet__title {
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 700;
    line-height: 1.1;
    color: var(--color-ink);
    margin: 0;
  }
  .discreet__sub {
    font-family: var(--font-body);
    font-size: 11.5px;
    font-weight: 400;
    line-height: 1.35;
    color: var(--color-ink-faint);
    margin: 3px 0 0;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.discreet_by_design",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading",
      "default": "Discreet by design"
    }
  ],
  "presets": [
    {
      "name": "t:general.discreet_by_design"
    }
  ]
}
{% endschema %}
