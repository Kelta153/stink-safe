{%- liquid
  assign current_variant = product.selected_or_first_available_variant
  assign has_only_default_variant = false
  if product.has_only_default_variant
    assign has_only_default_variant = true
  endif

  assign product_accent = '#2463EB'
  if product.tags contains 'crimewave'
    assign product_accent = '#F4A300'
  elsif product.tags contains 'snackverse'
    assign product_accent = '#EC4899'
  elsif product.tags contains 'horror-highs'
    assign product_accent = '#7C3AED'
  elsif product.tags contains 'horror-hotbox'
    assign product_accent = '#991B1B'
  endif
-%}

<div class="pdp">

  {%- comment -%} ─── GALLERY ─────────────────────────────────────────────── {%- endcomment -%}
  <div class="pdp__gallery">

    <div class="pdp__main-img" id="pdp-main-img">
      {%- if product.featured_image -%}
        {{ product.featured_image | image_url: width: 800 | image_tag:
          loading: 'eager',
          fetchpriority: 'high',
          alt: product.title,
          class: 'pdp__main-img-el',
          id: 'pdp-main-img-el'
        }}
      {%- else -%}
        <div
          class="pdp__main-placeholder"
          style="background: linear-gradient(135deg, {{ product_accent }}22 0%, {{ product_accent }}44 100%);"
          aria-hidden="true"
        ></div>
      {%- endif -%}
    </div>

    {%- if product.images.size > 1 -%}
      <div class="pdp__thumbs" role="list" aria-label="{{ 'products.gallery.thumbnails' | t }}">
        {%- for img in product.images -%}
          <button
            class="pdp__thumb{% if forloop.first %} pdp__thumb--active{% endif %}"
            type="button"
            data-src="{{ img | image_url: width: 800 }}"
            data-thumb-index="{{ forloop.index0 }}"
            aria-label="{{ 'products.gallery.view_image' | t: index: forloop.index }}"
            role="listitem"
          >
            {{ img | image_url: width: 104 | image_tag:
              loading: 'lazy',
              alt: product.title,
              width: 52,
              height: 52
            }}
          </button>
        {%- endfor -%}
      </div>
    {%- endif -%}

  </div>

  {%- comment -%} ─── INFO PANEL ──────────────────────────────────────────── {%- endcomment -%}
  <div class="pdp__info">

    {%- if product.vendor != blank -%}
      <p class="pdp__vendor">{{- product.vendor | escape -}}</p>
    {%- endif -%}

    <h1 class="pdp__title">{{- product.title | escape -}}</h1>

    <div class="pdp__meta-row">
      <span class="pdp__rating" aria-label="{{ 'products.rating.aria' | t: score: '4.9' }}">
        <span class="pdp__stars" aria-hidden="true">★★★★★</span>
        <span class="pdp__rating-num">4.9</span>
      </span>
      <span class="pdp__meta-dot" aria-hidden="true">·</span>
      <span class="pdp__designs">{{ 'products.designs_count' | t: count: 6 }}</span>
    </div>

    {%- comment -%} ─── PRODUCT FORM ─────────────────────────────────────── {%- endcomment -%}
    {% form 'product', product, id: 'pdp-form', data-product-id: product.id %}

      {%- comment -%} Variant hidden input — updated by JS {%- endcomment -%}
      <input
        type="hidden"
        name="id"
        id="pdp-variant-id"
        value="{{ current_variant.id }}"
      >

      {%- comment -%} ─── PRICE ROW ─────────────────────────────────────── {%- endcomment -%}
      <div class="pdp__price-row" id="pdp-price-row">
        <span class="pdp__price" id="pdp-price">
          {{- current_variant.price | money_without_trailing_zeros -}}
        </span>
        {%- if current_variant.compare_at_price > current_variant.price -%}
          <span class="pdp__compare" id="pdp-compare">
            {{- current_variant.compare_at_price | money_without_trailing_zeros -}}
          </span>
          {%- assign save_pct = current_variant.compare_at_price | minus: current_variant.price | times: 100 | divided_by: current_variant.compare_at_price -%}
          <span class="pdp__save-badge" id="pdp-save-badge">
            {{ 'products.save_percent' | t: percent: save_pct }}
          </span>
        {%- else -%}
          <span class="pdp__compare pdp__compare--hidden" id="pdp-compare"></span>
          <span class="pdp__save-badge pdp__save-badge--hidden" id="pdp-save-badge"></span>
        {%- endif -%}
      </div>

      {%- comment -%} ─── VARIANT PILLS ─────────────────────────────────── {%- endcomment -%}
      {%- unless has_only_default_variant -%}
        <div class="pdp__variants" id="pdp-variants">
          {%- for option in product.options_with_values -%}
            <div class="pdp__option-group">
              <p class="pdp__option-label">
                {{- option.name | escape -}}
              </p>
              <div class="pdp__pills" role="group" aria-label="{{ option.name | escape }}">
                {%- for value in option.values -%}
                  {%- liquid
                    assign option_index = forloop.parentloop.index0
                    assign is_selected = false
                    if option_index == 0
                      if current_variant.option1 == value
                        assign is_selected = true
                      endif
                    elsif option_index == 1
                      if current_variant.option2 == value
                        assign is_selected = true
                      endif
                    elsif option_index == 2
                      if current_variant.option3 == value
                        assign is_selected = true
                      endif
                    endif

                    assign is_sold_out = true
                    for variant in product.variants
                      if option_index == 0
                        if variant.option1 == value
                          if variant.available
                            assign is_sold_out = false
                          endif
                        endif
                      elsif option_index == 1
                        if variant.option2 == value
                          if variant.available
                            assign is_sold_out = false
                          endif
                        endif
                      elsif option_index == 2
                        if variant.option3 == value
                          if variant.available
                            assign is_sold_out = false
                          endif
                        endif
                      endif
                    endfor
                  -%}
                  <label
                    class="pdp__pill{% if is_selected %} pdp__pill--active{% endif %}{% if is_sold_out %} pdp__pill--soldout{% endif %}"
                    data-option-index="{{ option_index }}"
                    data-option-value="{{ value | escape }}"
                  >
                    <input
                      class="sr-only"
                      type="radio"
                      name="option-{{ option_index }}"
                      value="{{ value | escape }}"
                      {% if is_selected %}checked="checked"{% endif %}
                      {% if is_sold_out %}aria-label="{{ value | escape }} — {{ 'products.sold_out' | t }}"{% endif %}
                    >
                    {{- value | escape -}}
                  </label>
                {%- endfor -%}
              </div>
            </div>
          {%- endfor -%}
        </div>
      {%- endunless -%}

      {%- comment -%} ─── QTY + ADD TO CART ─────────────────────────────── {%- endcomment -%}
      <div class="pdp__atc-row">
        <div class="pdp__qty" role="group" aria-label="{{ 'products.quantity.label' | t }}">
          <button
            class="pdp__qty-btn"
            type="button"
            id="pdp-qty-minus"
            aria-label="{{ 'products.quantity.decrease' | t }}"
          >
            <svg width="14" height="2" viewBox="0 0 14 2" fill="none" aria-hidden="true">
              <rect x="0" y="0" width="14" height="2" rx="1" fill="currentColor"/>
            </svg>
          </button>
          <input
            class="pdp__qty-input"
            type="number"
            name="quantity"
            id="pdp-qty"
            value="1"
            min="1"
            max="99"
            aria-label="{{ 'products.quantity.label' | t }}"
          >
          <button
            class="pdp__qty-btn"
            type="button"
            id="pdp-qty-plus"
            aria-label="{{ 'products.quantity.increase' | t }}"
          >
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <rect x="6" y="0" width="2" height="14" rx="1" fill="currentColor"/>
              <rect x="0" y="6" width="14" height="2" rx="1" fill="currentColor"/>
            </svg>
          </button>
        </div>

        <button
          class="pdp__atc btn btn--primary"
          type="submit"
          name="add"
          id="pdp-atc"
          data-add-text="{{ 'products.add_to_cart' | t | escape }}"
          data-soldout-text="{{ 'products.sold_out' | t | escape }}"
          data-added-text="{{ 'products.added' | t | escape }}"
          {% unless current_variant.available %}disabled="disabled"{% endunless %}
        >
          <span class="pdp__atc-text" id="pdp-atc-text">
            {%- if current_variant.available -%}
              {{- 'products.add_to_cart' | t -}}
            {%- else -%}
              {{- 'products.sold_out' | t -}}
            {%- endif -%}
          </span>
        </button>
      </div>

    {% endform %}

    {%- comment -%} ─── DISCREET SHIPPING NOTE ────────────────────────────── {%- endcomment -%}
    <p class="pdp__discreet">
      <svg class="pdp__lock-icon" width="12" height="14" viewBox="0 0 12 14" fill="none" aria-hidden="true">
        <rect x="1" y="6" width="10" height="8" rx="2" fill="currentColor" opacity="0.15"/>
        <rect x="1" y="6" width="10" height="8" rx="2" stroke="currentColor" stroke-width="1.5"/>
        <path d="M3.5 6V4.5a2.5 2.5 0 0 1 5 0V6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        <circle cx="6" cy="10" r="1" fill="currentColor"/>
      </svg>
      {{ 'products.discreet_shipping' | t }}
    </p>

    {%- comment -%} ─── VOLUME PRICING ──────────────────────────────────────── {%- endcomment -%}
    {%- if section.settings.show_volume_pricing -%}
      <div class="pdp__volume">
        <button
          class="pdp__volume-toggle"
          type="button"
          id="pdp-volume-toggle"
          aria-expanded="false"
          aria-controls="pdp-volume-table"
        >
          <span class="pdp__volume-label">{{ 'products.volume_pricing.title' | t }}</span>
          <svg class="pdp__chevron" width="14" height="9" viewBox="0 0 14 9" fill="none" aria-hidden="true">
            <path d="M1 1l6 6 6-6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        <div class="pdp__volume-body" id="pdp-volume-table" hidden>
          <table class="pdp__vol-table" aria-label="{{ 'products.volume_pricing.title' | t }}">
            <thead>
              <tr>
                <th scope="col">{{ 'products.volume_pricing.qty' | t }}</th>
                <th scope="col">{{ 'products.volume_pricing.price' | t }}</th>
                <th scope="col">{{ 'products.volume_pricing.per_bag' | t }}</th>
                <th scope="col">{{ 'products.volume_pricing.save' | t }}</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>6</td>
                <td>£4.99</td>
                <td>£0.83</td>
                <td>—</td>
              </tr>
              <tr>
                <td>25</td>
                <td>£6.99</td>
                <td>£0.28</td>
                <td class="pdp__vol-save">{{ 'products.volume_pricing.save_pct' | t: percent: 66 }}</td>
              </tr>
              <tr>
                <td>50</td>
                <td>£9.99</td>
                <td>£0.20</td>
                <td class="pdp__vol-save">{{ 'products.volume_pricing.save_pct' | t: percent: 76 }}</td>
              </tr>
              <tr>
                <td>100</td>
                <td>£13.99</td>
                <td>£0.14</td>
                <td class="pdp__vol-save">{{ 'products.volume_pricing.save_pct' | t: percent: 83 }}</td>
              </tr>
              <tr>
                <td>200</td>
                <td>£22.99</td>
                <td>£0.11</td>
                <td class="pdp__vol-save">{{ 'products.volume_pricing.save_pct' | t: percent: 86 }}</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    {%- endif -%}

    {%- comment -%} ─── SPEC ACCORDION ──────────────────────────────────────── {%- endcomment -%}
    <div class="pdp__specs">
      <details class="pdp__spec">
        <summary class="pdp__spec-summary">
          <span class="pdp__spec-title">{{ 'products.spec.smell.title' | t }}</span>
          <svg class="pdp__spec-chevron" width="14" height="9" viewBox="0 0 14 9" fill="none" aria-hidden="true">
            <path d="M1 1l6 6 6-6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </summary>
        <div class="pdp__spec-body">
          <p>{{ 'products.spec.smell.body' | t }}</p>
        </div>
      </details>

      <details class="pdp__spec">
        <summary class="pdp__spec-summary">
          <span class="pdp__spec-title">{{ 'products.spec.dimensions.title' | t }}</span>
          <svg class="pdp__spec-chevron" width="14" height="9" viewBox="0 0 14 9" fill="none" aria-hidden="true">
            <path d="M1 1l6 6 6-6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </summary>
        <div class="pdp__spec-body">
          <p>{{ 'products.spec.dimensions.body' | t }}</p>
        </div>
      </details>

      <details class="pdp__spec">
        <summary class="pdp__spec-summary">
          <span class="pdp__spec-title">{{ 'products.spec.shipping.title' | t }}</span>
          <svg class="pdp__spec-chevron" width="14" height="9" viewBox="0 0 14 9" fill="none" aria-hidden="true">
            <path d="M1 1l6 6 6-6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </summary>
        <div class="pdp__spec-body">
          <p>{{ 'products.spec.shipping.body' | t }}</p>
        </div>
      </details>
    </div>

    {%- comment -%} ─── DESCRIPTION ─────────────────────────────────────────── {%- endcomment -%}
    {%- if product.description != blank -%}
      <div class="pdp__desc rte">
        {{ product.description }}
      </div>
    {%- endif -%}

  </div>{%- comment -%} /pdp__info {%- endcomment -%}

</div>{%- comment -%} /pdp {%- endcomment -%}

{%- comment -%} Variant JSON for JS {%- endcomment -%}
<script type="application/json" id="pdp-variants-json">
  {{ product.variants | json }}
</script>

{% stylesheet %}
  /* ── Layout ───────────────────────────────────────── */
  .pdp {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
    box-sizing: border-box;
  }

  @media (min-width: 768px) {
    .pdp {
      grid-template-columns: 1fr 1fr;
      gap: 32px;
      align-items: start;
    }
  }

  /* ── Gallery ─────────────────────────────────────── */
  .pdp__gallery {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .pdp__main-img {
    aspect-ratio: 1 / 1;
    border-radius: 16px;
    background: var(--color-mist);
    overflow: hidden;
    position: relative;
  }

  .pdp__main-img-el {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: opacity 0.2s ease;
  }

  .pdp__main-placeholder {
    width: 100%;
    height: 100%;
  }

  .pdp__thumbs {
    display: flex;
    flex-direction: row;
    gap: 8px;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding-bottom: 2px;
  }

  .pdp__thumbs::-webkit-scrollbar {
    display: none;
  }

  .pdp__thumb {
    flex: 0 0 52px;
    width: 52px;
    height: 52px;
    border-radius: 10px;
    overflow: hidden;
    border: 2px solid transparent;
    background: var(--color-mist);
    padding: 0;
    cursor: pointer;
    transition: border-color 0.15s ease;
    box-sizing: border-box;
  }

  .pdp__thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .pdp__thumb--active {
    border-color: var(--color-blue);
  }

  .pdp__thumb:focus-visible {
    outline: 2px solid var(--color-blue);
    outline-offset: 2px;
  }

  /* ── Info panel ──────────────────────────────────── */
  .pdp__info {
    display: flex;
    flex-direction: column;
    gap: 16px;
    padding: 16px var(--page-gutter);
  }

  @media (min-width: 768px) {
    .pdp__info {
      padding: 4px 0 0;
    }
  }

  /* ── Vendor ──────────────────────────────────────── */
  .pdp__vendor {
    font-family: var(--font-label);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-blue);
    margin: 0;
    line-height: 1;
  }

  /* ── Title ───────────────────────────────────────── */
  .pdp__title {
    font-family: var(--font-display);
    font-size: 22px;
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--color-ink);
    margin: 0;
  }

  /* ── Meta row ────────────────────────────────────── */
  .pdp__meta-row {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .pdp__rating {
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .pdp__stars {
    color: var(--color-sun);
    font-size: 13px;
    letter-spacing: -1px;
    line-height: 1;
  }

  .pdp__rating-num {
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 700;
    color: var(--color-ink);
  }

  .pdp__meta-dot {
    color: var(--color-ink-subtle);
    font-size: 12px;
  }

  .pdp__designs {
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 500;
    color: var(--color-ink-faint);
  }

  /* ── Price row ───────────────────────────────────── */
  .pdp__price-row {
    display: flex;
    align-items: baseline;
    gap: 8px;
    flex-wrap: wrap;
  }

  .pdp__price {
    font-family: var(--font-display);
    font-size: 26px;
    font-weight: 800;
    color: var(--color-ink);
    line-height: 1;
  }

  .pdp__compare {
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 500;
    color: var(--color-ink-subtle);
    text-decoration: line-through;
    line-height: 1;
  }

  .pdp__compare--hidden {
    display: none;
  }

  .pdp__save-badge {
    font-family: var(--font-label);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-white);
    background: var(--color-in-stock);
    border-radius: 999px;
    padding: 3px 8px;
    line-height: 1.4;
  }

  .pdp__save-badge--hidden {
    display: none;
  }

  /* ── Variants ────────────────────────────────────── */
  .pdp__variants {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .pdp__option-group {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .pdp__option-label {
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 600;
    color: var(--color-slate);
    text-transform: uppercase;
    letter-spacing: 0.07em;
    margin: 0;
  }

  .pdp__pills {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .pdp__pill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 8px 16px;
    border-radius: 999px;
    border: 1.5px solid var(--color-hairline);
    background: var(--color-white);
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 600;
    color: var(--color-ink);
    cursor: pointer;
    transition: border-color 0.12s ease, color 0.12s ease, background 0.12s ease;
    user-select: none;
    line-height: 1;
  }

  .pdp__pill:hover {
    border-color: var(--color-blue);
    color: var(--color-blue);
  }

  .pdp__pill--active {
    border-color: var(--color-blue);
    color: var(--color-blue);
    background: var(--color-mist);
  }

  .pdp__pill--soldout {
    color: var(--color-ink-subtle);
    border-color: var(--color-hairline);
    text-decoration: line-through;
    cursor: not-allowed;
    opacity: 0.6;
  }

  .pdp__pill--soldout:hover {
    border-color: var(--color-hairline);
    color: var(--color-ink-subtle);
  }

  .pdp__pill:focus-visible {
    outline: 2px solid var(--color-blue);
    outline-offset: 2px;
  }

  /* ── ATC row ─────────────────────────────────────── */
  .pdp__atc-row {
    display: flex;
    align-items: stretch;
    gap: 10px;
  }

  .pdp__qty {
    display: flex;
    align-items: center;
    border: 1.5px solid var(--color-hairline);
    border-radius: 12px;
    overflow: hidden;
    flex: 0 0 auto;
    background: var(--color-white);
  }

  .pdp__qty-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 48px;
    background: none;
    border: none;
    color: var(--color-ink);
    cursor: pointer;
    padding: 0;
    transition: color 0.12s ease;
    flex: 0 0 auto;
  }

  .pdp__qty-btn:hover {
    color: var(--color-blue);
  }

  .pdp__qty-btn:focus-visible {
    outline: 2px solid var(--color-blue);
    outline-offset: -2px;
  }

  .pdp__qty-input {
    width: 40px;
    height: 48px;
    border: none;
    background: none;
    text-align: center;
    font-family: var(--font-display);
    font-size: 15px;
    font-weight: 700;
    color: var(--color-ink);
    padding: 0;
    -moz-appearance: textfield;
    appearance: textfield;
  }

  .pdp__qty-input::-webkit-inner-spin-button,
  .pdp__qty-input::-webkit-outer-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }

  .pdp__qty-input:focus {
    outline: none;
  }

  .pdp__atc {
    flex: 1 1 auto;
    height: 48px;
    font-size: 14px;
    font-weight: 700;
    border-radius: 12px;
    border: none;
    cursor: pointer;
    background: var(--color-blue);
    color: var(--color-white);
    box-shadow: 0 8px 18px rgba(36, 99, 235, 0.28);
    transition: background 0.15s ease, box-shadow 0.15s ease, opacity 0.15s ease;
    font-family: var(--font-body);
    line-height: 1;
    padding: 0 20px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .pdp__atc:hover:not(:disabled) {
    background: var(--color-blue-pressed, #1D4ED8);
    box-shadow: 0 6px 14px rgba(36, 99, 235, 0.22);
  }

  .pdp__atc:disabled {
    background: var(--color-hairline);
    color: var(--color-ink-subtle);
    box-shadow: none;
    cursor: not-allowed;
  }

  .pdp__atc:focus-visible {
    outline: 2px solid var(--color-blue);
    outline-offset: 2px;
  }

  /* ── Discreet shipping ───────────────────────────── */
  .pdp__discreet {
    display: flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 500;
    color: var(--color-slate);
    margin: 0;
  }

  .pdp__lock-icon {
    flex: 0 0 auto;
    color: var(--color-slate);
  }

  /* ── Volume pricing ──────────────────────────────── */
  .pdp__volume {
    border: 1px solid var(--color-hairline);
    border-radius: 12px;
    overflow: hidden;
  }

  .pdp__volume-toggle {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px 14px;
    background: none;
    border: none;
    cursor: pointer;
    gap: 8px;
  }

  .pdp__volume-toggle:focus-visible {
    outline: 2px solid var(--color-blue);
    outline-offset: -2px;
  }

  .pdp__volume-label {
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 600;
    color: var(--color-ink);
  }

  .pdp__chevron {
    color: var(--color-slate);
    flex: 0 0 auto;
    transition: transform 0.2s ease;
  }

  .pdp__volume-toggle[aria-expanded="true"] .pdp__chevron {
    transform: rotate(180deg);
  }

  .pdp__volume-body {
    border-top: 1px solid var(--color-hairline);
    padding: 0;
  }

  .pdp__vol-table {
    width: 100%;
    border-collapse: collapse;
    font-family: var(--font-body);
    font-size: 12px;
  }

  .pdp__vol-table th {
    padding: 8px 10px;
    text-align: left;
    font-weight: 600;
    color: var(--color-slate);
    background: var(--color-mist);
    border-bottom: 1px solid var(--color-hairline);
    white-space: nowrap;
  }

  .pdp__vol-table td {
    padding: 9px 10px;
    color: var(--color-ink);
    border-bottom: 1px solid var(--color-hairline);
  }

  .pdp__vol-table tr:last-child td {
    border-bottom: none;
  }

  .pdp__vol-save {
    font-family: var(--font-label);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-in-stock);
  }

  /* ── Spec accordion ──────────────────────────────── */
  .pdp__specs {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--color-hairline);
    border-radius: 12px;
    overflow: hidden;
  }

  .pdp__spec {
    border-bottom: 1px solid var(--color-hairline);
  }

  .pdp__spec:last-child {
    border-bottom: none;
  }

  .pdp__spec-summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px 14px;
    cursor: pointer;
    list-style: none;
    gap: 8px;
    transition: background 0.12s ease;
  }

  .pdp__spec-summary::-webkit-details-marker {
    display: none;
  }

  .pdp__spec-summary:hover {
    background: var(--color-mist);
  }

  .pdp__spec-summary:focus-visible {
    outline: 2px solid var(--color-blue);
    outline-offset: -2px;
  }

  .pdp__spec-title {
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 600;
    color: var(--color-ink);
  }

  .pdp__spec-chevron {
    color: var(--color-slate);
    flex: 0 0 auto;
    transition: transform 0.2s ease;
  }

  .pdp__spec[open] > .pdp__spec-summary .pdp__spec-chevron {
    transform: rotate(180deg);
  }

  .pdp__spec-body {
    padding: 4px 14px 14px;
  }

  .pdp__spec-body p {
    font-family: var(--font-body);
    font-size: 13px;
    line-height: 1.55;
    color: var(--color-slate);
    margin: 0;
  }

  /* ── Description ─────────────────────────────────── */
  .pdp__desc {
    font-family: var(--font-body);
    font-size: 14px;
    line-height: 1.6;
    color: var(--color-slate);
    padding-top: 4px;
  }

  .pdp__desc p { margin: 0 0 10px; }
  .pdp__desc p:last-child { margin-bottom: 0; }

  /* ── SR-only utility ──────────────────────────────── */
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
{% endstylesheet %}

{% javascript %}
  (function () {
    var productData = null;
    var selectedOptions = [];
    var currentVariant = null;

    function init() {
      var jsonEl = document.getElementById('pdp-variants-json');
      if (!jsonEl) return;
      try {
        productData = JSON.parse(jsonEl.textContent);
      } catch (e) {
        return;
      }

      var variantIdInput = document.getElementById('pdp-variant-id');
      if (variantIdInput) {
        var currentId = parseInt(variantIdInput.value, 10);
        currentVariant = productData.find(function (v) { return v.id === currentId; });
        if (currentVariant) {
          selectedOptions = [
            currentVariant.option1 || null,
            currentVariant.option2 || null,
            currentVariant.option3 || null
          ];
        }
      }

      initThumbnails();
      initQtyStepper();
      initPills();
      initVolumePricing();
      initAtcAjax();
    }

    /* ─── AJAX add-to-cart ─────────────────────────────── */
    function initAtcAjax() {
      var form = document.getElementById('pdp-form');
      var atcBtn = document.getElementById('pdp-atc');
      var atcText = document.getElementById('pdp-atc-text');
      if (!form || !atcBtn) return;

      var addLabel = atcBtn.getAttribute('data-add-text') || (atcText ? atcText.textContent.trim() : 'Add to cart');
      var addedLabel = atcBtn.getAttribute('data-added-text') || 'Added!';

      form.addEventListener('submit', function (e) {
        e.preventDefault();
        if (atcBtn.disabled) return;

        var formData = new FormData(form);
        atcBtn.disabled = true;
        if (atcText) atcText.textContent = addedLabel;

        fetch('/cart/add.js', {
          method: 'POST',
          headers: { 'Accept': 'application/json' },
          body: formData
        })
          .then(function (r) { return r.json(); })
          .then(function () {
            return fetch('/cart.js').then(function (r) { return r.json(); });
          })
          .then(function (cart) {
            document.dispatchEvent(new CustomEvent('cart:updated', { detail: { count: cart.item_count } }));
            document.dispatchEvent(new CustomEvent('cart:open'));
            setTimeout(function () {
              atcBtn.disabled = false;
              if (atcText) atcText.textContent = addLabel;
            }, 1200);
          })
          .catch(function () {
            atcBtn.disabled = false;
            if (atcText) atcText.textContent = addLabel;
            form.submit();
          });
      });
    }

    /* ─── Thumbnails ──────────────────────────────────── */
    function initThumbnails() {
      var thumbs = document.querySelectorAll('.pdp__thumb');
      if (!thumbs.length) return;

      thumbs.forEach(function (btn) {
        btn.addEventListener('click', function () {
          var src = btn.getAttribute('data-src');
          if (!src) return;
          var imgEl = document.getElementById('pdp-main-img-el');
          if (!imgEl) return;
          imgEl.style.opacity = '0';
          imgEl.setAttribute('src', src);
          imgEl.onload = function () {
            imgEl.style.opacity = '1';
          };
          thumbs.forEach(function (t) { t.classList.remove('pdp__thumb--active'); });
          btn.classList.add('pdp__thumb--active');
        });
      });
    }

    /* ─── Quantity stepper ────────────────────────────── */
    function initQtyStepper() {
      var input = document.getElementById('pdp-qty');
      var minus = document.getElementById('pdp-qty-minus');
      var plus = document.getElementById('pdp-qty-plus');
      if (!input || !minus || !plus) return;

      minus.addEventListener('click', function () {
        var val = parseInt(input.value, 10) || 1;
        if (val > 1) {
          input.value = val - 1;
        }
      });

      plus.addEventListener('click', function () {
        var val = parseInt(input.value, 10) || 1;
        if (val < 99) {
          input.value = val + 1;
        }
      });

      input.addEventListener('change', function () {
        var val = parseInt(input.value, 10);
        if (isNaN(val) || val < 1) input.value = 1;
        if (val > 99) input.value = 99;
      });
    }

    /* ─── Pill selection + variant sync ──────────────── */
    function initPills() {
      var pills = document.querySelectorAll('.pdp__pill');
      pills.forEach(function (pill) {
        pill.addEventListener('click', function () {
          if (pill.classList.contains('pdp__pill--soldout')) return;
          var optionIndex = parseInt(pill.getAttribute('data-option-index'), 10);
          var optionValue = pill.getAttribute('data-option-value');
          selectedOptions[optionIndex] = optionValue;

          var group = pill.closest('.pdp__pills');
          if (group) {
            group.querySelectorAll('.pdp__pill').forEach(function (p) {
              p.classList.remove('pdp__pill--active');
            });
          }
          pill.classList.add('pdp__pill--active');

          var radio = pill.querySelector('input[type="radio"]');
          if (radio) radio.checked = true;

          syncVariant();
        });
      });
    }

    function syncVariant() {
      if (!productData) return;

      var matched = null;
      productData.forEach(function (variant) {
        if (matched) return;
        var o1 = selectedOptions[0] === null || variant.option1 === selectedOptions[0];
        var o2 = selectedOptions[1] === null || variant.option2 === selectedOptions[1];
        var o3 = selectedOptions[2] === null || variant.option3 === selectedOptions[2];
        if (o1 && o2 && o3) {
          matched = variant;
        }
      });

      if (!matched) return;
      currentVariant = matched;

      var idInput = document.getElementById('pdp-variant-id');
      if (idInput) idInput.value = matched.id;

      updatePrice(matched);
      updateAtcButton(matched);
      updateVolumePricing(matched);
    }

    function formatMoney(cents) {
      if (cents === null || cents === undefined) return '';
      var pounds = cents / 100;
      if (pounds % 1 === 0) {
        return '£' + pounds.toFixed(0);
      }
      return '£' + pounds.toFixed(2);
    }

    function updatePrice(variant) {
      var priceEl = document.getElementById('pdp-price');
      var compareEl = document.getElementById('pdp-compare');
      var saveEl = document.getElementById('pdp-save-badge');

      if (priceEl) priceEl.textContent = formatMoney(variant.price);

      if (compareEl && saveEl) {
        if (variant.compare_at_price && variant.compare_at_price > variant.price) {
          compareEl.textContent = formatMoney(variant.compare_at_price);
          compareEl.classList.remove('pdp__compare--hidden');
          var pct = Math.round((variant.compare_at_price - variant.price) * 100 / variant.compare_at_price);
          saveEl.textContent = 'Save ' + pct + '%';
          saveEl.classList.remove('pdp__save-badge--hidden');
        } else {
          compareEl.textContent = '';
          compareEl.classList.add('pdp__compare--hidden');
          saveEl.textContent = '';
          saveEl.classList.add('pdp__save-badge--hidden');
        }
      }
    }

    function updateAtcButton(variant) {
      var btn = document.getElementById('pdp-atc');
      var txt = document.getElementById('pdp-atc-text');
      if (!btn || !txt) return;
      if (variant.available) {
        btn.disabled = false;
        txt.textContent = btn.getAttribute('data-add-text') || 'Add to cart';
      } else {
        btn.disabled = true;
        txt.textContent = btn.getAttribute('data-soldout-text') || 'Sold out';
      }
    }

    /* ─── Volume pricing toggle ───────────────────────── */
    function initVolumePricing() {
      var toggle = document.getElementById('pdp-volume-toggle');
      var body = document.getElementById('pdp-volume-table');
      if (!toggle || !body) return;

      toggle.addEventListener('click', function () {
        var expanded = toggle.getAttribute('aria-expanded') === 'true';
        toggle.setAttribute('aria-expanded', String(!expanded));
        if (expanded) {
          body.hidden = true;
        } else {
          body.hidden = false;
        }
      });
    }

    function updateVolumePricing(variant) {
      var p1 = document.getElementById('pdp-vol-price-1');
      var p3 = document.getElementById('pdp-vol-price-3');
      var p6 = document.getElementById('pdp-vol-price-6');
      if (!p1 || !p3 || !p6) return;

      var base = variant.price;
      p1.textContent = formatMoney(base);
      p3.textContent = formatMoney(Math.round(base * 0.9));
      p6.textContent = formatMoney(Math.round(base * 0.83));
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
  })();
{% endjavascript %}

{% schema %}
{
  "name": "t:general.product",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_volume_pricing",
      "label": "t:labels.show_volume_pricing",
      "default": true
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}
