<div class="trust-band full-width">
  <div class="trust-band__inner">

    <div class="trust-band__item">
      <svg viewBox="0 0 24 24" fill="none" stroke="#2463EB" stroke-width="1.85" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <rect x="3" y="8" width="18" height="12" rx="2"/>
        <path d="M8 8V6a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/>
      </svg>
      <span>{{ 'sections.trust_band.plain_parcels' | t }}</span>
    </div>

    <div class="trust-band__item">
      <svg viewBox="0 0 24 24" fill="none" stroke="#2463EB" stroke-width="1.85" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M3 12h13l-3-3m3 3-3 3"/>
        <path d="M16 6h4v12h-4"/>
      </svg>
      <span>{{ 'sections.trust_band.free_shipping' | t }}</span>
    </div>

    <div class="trust-band__item">
      <svg viewBox="0 0 24 24" fill="none" stroke="#2463EB" stroke-width="1.85" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M3 7h18v10H3z"/>
        <path d="M3 11h18"/>
      </svg>
      <span>{{ 'sections.trust_band.easy_returns' | t }}</span>
    </div>

    <div class="trust-band__item">
      <svg viewBox="0 0 24 24" fill="none" stroke="#2463EB" stroke-width="1.85" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <rect x="5" y="11" width="14" height="9" rx="2"/>
        <path d="M8 11V8a4 4 0 0 1 8 0v3"/>
      </svg>
      <span>{{ 'sections.trust_band.secure_checkout' | t }}</span>
    </div>

  </div>
</div>

{% stylesheet %}
  .trust-band {
    background: var(--color-mist);
  }

  .trust-band__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px 10px;
    max-width: 1200px;
    margin: 0 auto;
    padding: 24px 40px;
  }

  .trust-band__item {
    display: flex;
    align-items: center;
    gap: 10px;
    justify-content: flex-start;
  }

  .trust-band__item svg {
    width: 20px;
    height: 20px;
    flex: 0 0 auto;
  }

  .trust-band__item span {
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 600;
    line-height: 1.3;
    color: var(--color-ink);
  }

  @media (min-width: 768px) {
    .trust-band__inner {
      grid-template-columns: repeat(4, 1fr);
      gap: 24px;
      padding: 30px 40px;
    }

    .trust-band__item {
      justify-content: center;
    }

    .trust-band__item svg {
      width: 22px;
      height: 22px;
    }

    .trust-band__item span {
      font-size: 14px;
    }
  }
{% endstylesheet %}

