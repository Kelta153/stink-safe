[
  {
    "name": "theme_info",
    "theme_name": "Stink Safe",
    "theme_version": "1.0.0",
    "theme_author": "Stink Safe Ltd",
    "theme_documentation_url": "https://help.shopify.com/manual/online-store/themes",
    "theme_support_url": "https://support.shopify.com/"
  },
  {
    "name": "t:general.layout",
    "settings": [
      {
        "type": "select",
        "id": "max_page_width",
        "label": "t:labels.page_width",
        "options": [
          { "value": "90rem", "label": "t:options.page_width.narrow" },
          { "value": "110rem", "label": "t:options.page_width.wide" }
        ],
        "default": "90rem"
      },
      {
        "type": "range",
        "id": "min_page_margin",
        "min": 10,
        "max": 60,
        "step": 2,
        "unit": "px",
        "label": "t:labels.page_margin",
        "default": 16
      }
    ]
  },
  {
    "name": "t:general.colors",
    "settings": [
      {
        "type": "color",
        "id": "background_color",
        "default": "#FFFFFF",
        "label": "t:labels.background"
      },
      {
        "type": "color",
        "id": "foreground_color",
        "default": "#0B1220",
        "label": "t:labels.foreground"
      },
      {
        "type": "range",
        "id": "input_corner_radius",
        "min": 0,
        "max": 20,
        "step": 1,
        "unit": "px",
        "label": "t:labels.input_corner_radius",
        "default": 8
      }
    ]
  },
  {
    "name": "t:general.announcement_bar",
    "settings": [
      {
        "type": "checkbox",
        "id": "show_announcement",
        "default": true,
        "label": "t:labels.show_announcement"
      },
      {
        "type": "text",
        "id": "announcement_text",
        "default": "Free shipping on orders over £25 — Ships discreetly",
        "label": "t:labels.announcement_text"
      }
    ]
  }
]
