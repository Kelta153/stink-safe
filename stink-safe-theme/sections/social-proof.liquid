<div class="social-proof">
  <div class="social-proof__inner">

    <div class="social-proof__header">
      <h2 class="social-proof__heading">
        {{- section.settings.heading | default: '#StinkSafe in the wild' | escape -}}
      </h2>
      {%- if section.settings.follow_url != blank -%}
        <a href="{{ section.settings.follow_url }}" class="social-proof__follow" target="_blank" rel="noopener noreferrer">
          {{- section.settings.follow_label | default: 'Follow @stinksafe →' | escape -}}
        </a>
      {%- else -%}
        <span class="social-proof__follow">{{- section.settings.follow_label | default: 'Follow @stinksafe →' | escape -}}</span>
      {%- endif -%}
    </div>

    {%- if section.settings.review_text != blank -%}
      <div class="social-proof__quote-wrap">
        <div class="social-proof__bubble">
          <p class="social-proof__quote">&#8220;{{- section.settings.review_text | escape -}}&#8221;</p>
        </div>
        <div class="social-proof__reviewer">
          <div class="social-proof__avatar" aria-hidden="true"></div>
          <div>
            <p class="social-proof__name">{{- section.settings.reviewer_name | default: 'Verified buyer' | escape -}}</p>
          </div>
        </div>
      </div>
    {%- endif -%}

    <div class="social-proof__ugc">
      {%- assign ugc_accents = '#EC4899,#F4A300,#2463EB,#7C3AED,#16A34A' | split: ',' -%}
      {%- for i in (1..5) -%}
        {%- assign ugc_key = 'ugc_image_' | append: i -%}
        {%- assign ugc_img = section.settings[ugc_key] -%}
        {%- assign ugc_accent = ugc_accents[forloop.index0] -%}
        <div class="social-proof__ugc-item">
          {%- if ugc_img != blank -%}
            {{ ugc_img | image_url: width: 300 | image_tag: loading: 'lazy', alt: '' }}
          {%- else -%}
            <div
              class="social-proof__ugc-placeholder"
              style="background: repeating-linear-gradient(135deg, {{ ugc_accent }}26, {{ ugc_accent }}26 5px, {{ ugc_accent }}0d 5px, {{ ugc_accent }}0d 10px); border: 1px dashed {{ ugc_accent }}70;"
              aria-hidden="true"
            ></div>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>

  </div>
</div>

{% stylesheet %}
  .social-proof {
    padding: 16px 0 6px;
  }

  .social-proof__inner {
    /* mobile: no wrapper, page grid provides gutters */
  }

  .social-proof__header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 14px;
  }

  .social-proof__heading {
    font-family: var(--font-display);
    font-size: 20px;
    font-weight: 800;
    line-height: 1;
    color: var(--color-ink);
    margin: 0;
    letter-spacing: -0.01em;
  }

  .social-proof__follow {
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 700;
    color: var(--color-blue);
    text-decoration: none;
    white-space: nowrap;
  }

  .social-proof__quote-wrap {
    margin-bottom: 14px;
  }

  .social-proof__bubble {
    background: var(--color-mist);
    border-radius: 16px;
    padding: 14px 16px;
  }

  .social-proof__quote {
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 500;
    line-height: 1.55;
    color: var(--color-ink);
    margin: 0;
  }

  .social-proof__reviewer {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-top: 10px;
  }

  .social-proof__avatar {
    width: 30px;
    height: 30px;
    border-radius: 50%;
    flex: 0 0 auto;
    background: repeating-linear-gradient(135deg, #7C3AED33, #7C3AED33 5px, #7C3AED0d 5px, #7C3AED0d 10px);
    border: 1px dashed #7C3AED70;
  }

  .social-proof__name {
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 700;
    color: var(--color-ink);
    margin: 0;
  }

  /* UGC grid: 4 across on mobile, 5 on desktop */
  .social-proof__ugc {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 8px;
  }

  .social-proof__ugc-item:nth-child(5) {
    display: none;
  }

  .social-proof__ugc-item {
    border-radius: 10px;
    overflow: hidden;
    aspect-ratio: 1;
  }

  .social-proof__ugc-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .social-proof__ugc-placeholder {
    width: 100%;
    height: 100%;
  }

  @media (min-width: 768px) {
    .social-proof {
      padding: 0;
    }

    .social-proof__inner {
      max-width: 1200px;
      margin: 0 auto;
      padding: 48px 40px 8px;
    }

    .social-proof__heading {
      font-size: 30px;
    }

    .social-proof__follow {
      font-size: 14px;
    }

    .social-proof__quote-wrap {
      display: none;
    }

    .social-proof__ugc {
      grid-template-columns: repeat(5, 1fr);
      gap: 16px;
    }

    .social-proof__ugc-item:nth-child(5) {
      display: block;
    }

    .social-proof__ugc-item {
      border-radius: 14px;
      aspect-ratio: auto;
      height: 200px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.social_proof",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading",
      "default": "#StinkSafe in the wild"
    },
    {
      "type": "text",
      "id": "follow_label",
      "label": "t:labels.follow_label",
      "default": "Follow @stinksafe →"
    },
    {
      "type": "url",
      "id": "follow_url",
      "label": "t:labels.follow_url"
    },
    {
      "type": "textarea",
      "id": "review_text",
      "label": "t:labels.review_text",
      "info": "Optional — shown on mobile only. Leave blank to hide."
    },
    {
      "type": "text",
      "id": "reviewer_name",
      "label": "t:labels.reviewer_name",
      "default": "Verified buyer"
    },
    {
      "type": "header",
      "content": "t:general.ugc_photos"
    },
    {
      "type": "image_picker",
      "id": "ugc_image_1",
      "label": "t:labels.ugc_image_1"
    },
    {
      "type": "image_picker",
      "id": "ugc_image_2",
      "label": "t:labels.ugc_image_2"
    },
    {
      "type": "image_picker",
      "id": "ugc_image_3",
      "label": "t:labels.ugc_image_3"
    },
    {
      "type": "image_picker",
      "id": "ugc_image_4",
      "label": "t:labels.ugc_image_4"
    },
    {
      "type": "image_picker",
      "id": "ugc_image_5",
      "label": "t:labels.ugc_image_5"
    }
  ],
  "presets": [
    {
      "name": "t:general.social_proof"
    }
  ]
}
{% endschema %}
