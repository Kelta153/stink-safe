<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    {%- render 'css-variables' -%}

    {%- comment -%} Google Fonts: Plus Jakarta Sans · Inter · JetBrains Mono {%- endcomment -%}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@500;700&family=Plus+Jakarta+Sans:ital,wght@0,600;0,700;0,800;1,700&display=swap"
      rel="stylesheet"
    >

    {{ 'critical.css' | asset_url | stylesheet_tag: preload: true }}
    {{ 'base.css' | asset_url | stylesheet_tag }}

    {%- render 'meta-tags' -%}

    {{ content_for_header }}
  </head>

  <body>
    {%- sections 'header-group' -%}

    <main id="main-content" tabindex="-1">
      {{ content_for_layout }}
    </main>

    {%- sections 'footer-group' -%}

    {%- section 'cart-drawer' -%}
  </body>
</html>
