{% doc %}
  Renders a product card with art placeholder, collection badge, status, rating, and price.

  @param {product} product - The product to display
  @param {string} [accent] - Hex accent colour for art placeholder (auto-detected from product tags if omitted)
  @param {string} [badge_text] - Collection badge label (defaults to product type)

  @example
  {% render 'product-card', product: product, accent: '#F4A300', badge_text: 'Crimewave' %}
{% enddoc %}

{%- liquid
  unless accent
    assign accent = '#2463EB'
    if product.tags contains 'crimewave'
      assign accent = '#F4A300'
    elsif product.tags contains 'snackverse'
      assign accent = '#EC4899'
    elsif product.tags contains 'horror-highs'
      assign accent = '#7C3AED'
    elsif product.tags contains 'horror-hotbox'
      assign accent = '#991B1B'
    endif
  endunless

  unless badge_text
    assign badge_text = product.type | default: ''
  endunless

  if product.available
    assign status_text = 'In stock'
    assign status_color = '#16A34A'
  else
    assign status_text = 'Sold out'
    assign status_color = '#E0472C'
  endif
-%}

<a href="{{ product.url }}" class="product-card">
  <div
    class="product-card__art"
    style="background: repeating-linear-gradient(135deg, {{ accent }}26, {{ accent }}26 7px, {{ accent }}0d 7px, {{ accent }}0d 14px); border: 1px dashed {{ accent }}70;"
  >
    {%- if product.featured_image != blank -%}
      {{ product.featured_image | image_url: width: 300 | image_tag: class: 'product-card__art-img', loading: 'lazy', alt: product.title }}
    {%- else -%}
      <span class="product-card__art-lbl" style="color: {{ accent }}">{{- product.title -}}&nbsp;art</span>
    {%- endif -%}
    {%- if badge_text != blank -%}
      <span class="product-card__badge" style="background: {{ accent }}">{{- badge_text | escape -}}</span>
    {%- endif -%}
    <span class="product-card__status" style="color: {{ status_color }}; border-color: {{ status_color }}">
      {{- status_text -}}
    </span>
  </div>
  <p class="product-card__title">{{- product.title | escape -}}</p>
  <p class="product-card__sub">{{ 'products.designs_count' | t: count: 6 }}</p>
  <div class="product-card__foot">
    <div>
      <div class="product-card__rating">★ 4.9</div>
      <div class="product-card__price">{{- product.price | money_without_trailing_zeros -}}</div>
    </div>
    <span class="product-card__add" aria-label="{{ 'products.quick_add' | t }}">＋</span>
  </div>
</a>

{% stylesheet %}
  .product-card {
    display: block;
    background: #fff;
    border: 1px solid var(--color-mist);
    border-radius: 16px;
    box-shadow: 0 6px 18px rgba(11, 18, 32, 0.06);
    padding: 8px;
    text-decoration: none;
    box-sizing: border-box;
    position: relative;
  }
  .product-card__art {
    height: 116px;
    border-radius: 10px;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 8px;
    overflow: hidden;
  }
  .product-card__art-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .product-card__art-lbl {
    font-family: var(--font-label);
    font-size: 9px;
    font-weight: 500;
    text-transform: uppercase;
    text-align: center;
    padding: 0 6px;
    opacity: 0.9;
    line-height: 1.3;
  }
  .product-card__badge {
    position: absolute;
    top: 6px;
    left: 6px;
    color: #fff;
    font-family: var(--font-body);
    font-size: 9px;
    font-weight: 700;
    padding: 3px 6px;
    border-radius: 6px;
    line-height: 1;
  }
  .product-card__status {
    position: absolute;
    top: 6px;
    right: 6px;
    background: #fff;
    font-family: var(--font-body);
    font-size: 8px;
    font-weight: 700;
    padding: 3px 5px;
    border-radius: 10px;
    border: 1px solid;
    line-height: 1;
  }
  .product-card__title {
    font-family: var(--font-display);
    font-size: 14px;
    font-weight: 700;
    line-height: 1.15;
    color: var(--color-ink);
    margin: 2px 0;
  }
  .product-card__sub {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 500;
    line-height: 1;
    color: var(--color-ink-faint);
    margin-bottom: 2px;
  }
  .product-card__foot {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    margin-top: 6px;
  }
  .product-card__rating {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 600;
    line-height: 1.4;
    color: var(--color-ink-faint);
  }
  .product-card__price {
    font-family: var(--font-display);
    font-size: 15px;
    font-weight: 800;
    line-height: 1.1;
    color: var(--color-ink);
  }
  .product-card__add {
    width: 30px;
    height: 30px;
    border-radius: 50%;
    background: var(--color-blue);
    color: #fff;
    font-family: var(--font-body);
    font-size: 17px;
    font-weight: 600;
    display: flex;
    align-items: center;
    justify-content: center;
    flex: 0 0 auto;
    line-height: 1;
  }
{% endstylesheet %}
