{%- liquid
  assign story_url = section.settings.story_url | default: '/pages/about'
-%}

<div class="brand-story">
  <div class="brand-story__inner">
    <div class="brand-story__panel">
      <div class="brand-story__dots" aria-hidden="true"></div>

      <div class="brand-story__left">
        <p class="brand-story__eyebrow">{{- section.settings.eyebrow | default: 'Our story' | escape -}}</p>
        <h2 class="brand-story__heading">{{- section.settings.heading | default: "Storage you'll actually want to show off." | escape -}}</h2>
        <p class="brand-story__body">{{- section.settings.body | default: 'Odour-control storage always looked like an afterthought. We put collectible comic art on a properly engineered, odour-resistant pack — useful, discreet and genuinely nice to own.' | escape -}}</p>
        <a href="{{ story_url }}" class="brand-story__cta">
          {{- section.settings.cta | default: 'Read our story' | escape -}}
        </a>
      </div>

      <div class="brand-story__right">
        {%- if section.settings.image != blank -%}
          {{ section.settings.image | image_url: width: 700 | image_tag: loading: 'lazy', alt: '' }}
        {%- else -%}
          <div class="brand-story__ph">
            <span>Founder &middot; workshop</span>
          </div>
        {%- endif -%}
      </div>

    </div>
  </div>
</div>

{% stylesheet %}
  .brand-story {
    padding: 24px 0;
  }

  .brand-story__inner {
    /* mobile: page grid gutters apply */
  }

  .brand-story__panel {
    background: var(--color-ink);
    border-radius: 20px;
    padding: 32px 24px;
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .brand-story__dots {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(rgba(255, 255, 255, 0.05) 1.5px, transparent 1.7px);
    background-size: 16px 16px;
    pointer-events: none;
  }

  .brand-story__left {
    position: relative;
    display: flex;
    flex-direction: column;
  }

  .brand-story__eyebrow {
    font-family: var(--font-label);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #7FA8FF;
    margin: 0;
  }

  .brand-story__heading {
    font-family: var(--font-display);
    font-size: 24px;
    font-weight: 800;
    line-height: 1.2;
    color: var(--color-white);
    margin: 14px 0 0;
    letter-spacing: -0.01em;
  }

  .brand-story__body {
    font-family: var(--font-body);
    font-size: 14px;
    line-height: 1.65;
    color: var(--color-ink-subtle);
    margin: 14px 0 0;
  }

  .brand-story__cta {
    display: inline-block;
    background: var(--color-white);
    color: var(--color-ink);
    border: none;
    border-radius: 12px;
    padding: 13px 22px;
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 700;
    text-decoration: none;
    margin-top: 22px;
    line-height: 1;
  }

  .brand-story__right {
    position: relative;
    border-radius: 14px;
    overflow: hidden;
    height: 200px;
  }

  .brand-story__right img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .brand-story__ph {
    width: 100%;
    height: 100%;
    background: repeating-linear-gradient(135deg, #7FA8FF1a, #7FA8FF1a 7px, transparent 7px, transparent 14px);
    border: 1px dashed #7FA8FF50;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .brand-story__ph span {
    font-family: var(--font-label);
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    color: #7FA8FF;
  }

  @media (min-width: 768px) {
    .brand-story {
      padding: 0;
    }

    .brand-story__inner {
      max-width: 1200px;
      margin: 0 auto;
      padding: 56px 40px;
    }

    .brand-story__panel {
      flex-direction: row;
      align-items: center;
      gap: 48px;
      padding: 56px;
      border-radius: 24px;
    }

    .brand-story__left {
      flex: 1.2;
    }

    .brand-story__heading {
      font-size: 34px;
    }

    .brand-story__body {
      font-size: 16px;
      max-width: 520px;
    }

    .brand-story__cta {
      padding: 15px 26px;
      font-size: 15px;
    }

    .brand-story__right {
      flex: 1;
      height: 280px;
      border-radius: 18px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.brand_story",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:labels.eyebrow",
      "default": "Our story"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading",
      "default": "Storage you'll actually want to show off."
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "t:labels.body",
      "default": "Odour-control storage always looked like an afterthought. We put collectible comic art on a properly engineered, odour-resistant pack — useful, discreet and genuinely nice to own."
    },
    {
      "type": "text",
      "id": "cta",
      "label": "t:labels.cta_text",
      "default": "Read our story"
    },
    {
      "type": "url",
      "id": "story_url",
      "label": "t:labels.story_url"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:labels.image"
    }
  ],
  "presets": [
    {
      "name": "t:general.brand_story"
    }
  ]
}
{% endschema %}
