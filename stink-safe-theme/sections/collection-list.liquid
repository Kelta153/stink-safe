{%- liquid
  assign see_all_url = section.settings.see_all_url | default: routes.collections_url
-%}

<div class="col-list">
  <div class="col-list__header">
    <h2 class="col-list__heading">
      {{- section.settings.heading | default: 'Shop by collection' | escape -}}
    </h2>
    <a href="{{ see_all_url }}" class="col-list__see-all">
      {{- section.settings.see_all_text | default: 'See all' | escape -}}
    </a>
  </div>

  <div class="col-list__scroll">
    {%- if section.settings.collections != blank -%}
      {%- for collection in section.settings.collections -%}
        {%- liquid
          assign tile_accent = '#2463EB'
          assign col_h = collection.handle
          if col_h contains 'crimewave'
            assign tile_accent = '#F4A300'
          elsif col_h contains 'snackverse'
            assign tile_accent = '#EC4899'
          elsif col_h contains 'horror-highs' or col_h contains 'horror_highs'
            assign tile_accent = '#7C3AED'
          elsif col_h contains 'horror-hotbox' or col_h contains 'horror_hotbox'
            assign tile_accent = '#991B1B'
          endif
        -%}
        <a href="{{ collection.url }}" class="col-list__tile">
          <div class="col-list__img-wrap">
            {%- if collection.featured_image != blank -%}
              {{ collection.featured_image | image_url: width: 260 | image_tag: loading: 'lazy', alt: collection.title }}
            {%- else -%}
              <div
                class="col-list__placeholder"
                style="background: repeating-linear-gradient(135deg, {{ tile_accent }}26, {{ tile_accent }}26 7px, {{ tile_accent }}0d 7px, {{ tile_accent }}0d 14px); border: 1px dashed {{ tile_accent }}70;"
              >
                <span style="color: {{ tile_accent }}">{{- collection.title | escape -}}</span>
              </div>
            {%- endif -%}
            {%- if forloop.first -%}
              <span class="col-list__badge-new">NEW</span>
            {%- endif -%}
          </div>
          <p class="col-list__title">{{- collection.title | escape -}}</p>
          <p class="col-list__issue">
            {%- if collection.metafields.custom.issue_range != blank -%}
              {{- collection.metafields.custom.issue_range -}}
            {%- else -%}
              ISSUE 01–06
            {%- endif -%}
          </p>
        </a>
      {%- endfor -%}
    {%- else -%}
      {%- assign placeholder_cols = 'Cartoon Crimewave,Snackverse,Horror Highs,Horror Hotbox' | split: ',' -%}
      {%- assign placeholder_accents = '#F4A300,#EC4899,#7C3AED,#991B1B' | split: ',' -%}
      {%- for label in placeholder_cols -%}
        {%- assign ph_accent = placeholder_accents[forloop.index0] -%}
        <div class="col-list__tile col-list__tile--placeholder">
          <div class="col-list__img-wrap">
            <div
              class="col-list__placeholder"
              style="background: repeating-linear-gradient(135deg, {{ ph_accent }}26, {{ ph_accent }}26 7px, {{ ph_accent }}0d 7px, {{ ph_accent }}0d 14px); border: 1px dashed {{ ph_accent }}70;"
            >
              <span style="color: {{ ph_accent }}">{{- label | escape -}}</span>
            </div>
            {%- if forloop.first -%}<span class="col-list__badge-new">NEW</span>{%- endif -%}
          </div>
          <p class="col-list__title">{{- label | escape -}}</p>
          <p class="col-list__issue">ISSUE 01–06</p>
        </div>
      {%- endfor -%}
    {%- endif -%}
  </div>
</div>

{% stylesheet %}
  .col-list {
    padding: 18px 0 6px;
  }
  .col-list__header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    padding: 0 var(--page-gutter);
    margin-bottom: 12px;
  }
  .col-list__heading {
    font-family: var(--font-display);
    font-size: 18px;
    font-weight: 800;
    line-height: 1;
    color: var(--color-ink);
    margin: 0;
  }
  .col-list__see-all {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 700;
    color: var(--color-blue);
    text-decoration: none;
  }
  .col-list__scroll {
    display: flex;
    gap: 12px;
    overflow-x: auto;
    padding: 0 var(--page-gutter) 6px;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }
  .col-list__scroll::-webkit-scrollbar { display: none; }
  .col-list__tile {
    flex: 0 0 auto;
    width: 130px;
    text-decoration: none;
  }
  .col-list__tile--placeholder {
    cursor: default;
  }
  .col-list__img-wrap {
    position: relative;
    height: 152px;
    border-radius: 14px;
    overflow: hidden;
  }
  .col-list__img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .col-list__placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .col-list__placeholder span {
    font-family: var(--font-label);
    font-size: 9px;
    font-weight: 500;
    text-transform: uppercase;
    text-align: center;
    padding: 0 6px;
    opacity: 0.9;
    line-height: 1.3;
  }
  .col-list__badge-new {
    position: absolute;
    top: 8px;
    left: 8px;
    background: #29791E;
    color: #fff;
    font-family: var(--font-body);
    font-size: 9px;
    font-weight: 800;
    padding: 4px 7px;
    border-radius: 6px;
    transform: rotate(-4deg);
    line-height: 1;
  }
  .col-list__title {
    font-family: var(--font-display);
    font-size: 13px;
    font-weight: 700;
    line-height: 1.15;
    color: var(--color-ink);
    margin: 8px 0 0;
  }
  .col-list__issue {
    font-family: var(--font-label);
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.08em;
    color: var(--color-ink-faint);
    margin: 4px 0 0;
  }
  @media (min-width: 640px) {
    .col-list__scroll {
      overflow-x: visible;
      flex-wrap: wrap;
      gap: 16px;
    }
    .col-list__tile {
      flex: 1 1 0;
      width: auto;
    }
    .col-list__img-wrap {
      height: 260px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.collection_list",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading",
      "default": "Shop by collection"
    },
    {
      "type": "text",
      "id": "see_all_text",
      "label": "t:labels.see_all_text",
      "default": "See all"
    },
    {
      "type": "url",
      "id": "see_all_url",
      "label": "t:labels.see_all_url"
    },
    {
      "type": "collection_list",
      "id": "collections",
      "label": "t:labels.collections",
      "limit": 8
    }
  ],
  "presets": [
    {
      "name": "t:general.collection_list"
    }
  ]
}
{% endschema %}
