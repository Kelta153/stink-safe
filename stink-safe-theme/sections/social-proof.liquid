<div class="social-proof">

  <h2 class="social-proof__heading">
    <span class="social-proof__star" aria-hidden="true">★</span>
    {{- section.settings.rating_summary | default: '4.9 from 300+ verified reviews' | escape -}}
  </h2>

  {%- if section.settings.review_text != blank -%}
    <div class="social-proof__bubble">
      <p class="social-proof__quote">&#8220;{{- section.settings.review_text | escape -}}&#8221;</p>
      <span class="social-proof__tail" aria-hidden="true"></span>
    </div>
  {%- endif -%}

  <div class="social-proof__reviewer">
    <div class="social-proof__avatar" aria-hidden="true"></div>
    <div>
      <p class="social-proof__name">{{- section.settings.reviewer_name | default: 'Maya R. · Verified buyer' | escape -}}</p>
      <p class="social-proof__stars" aria-label="5 stars">★★★★★</p>
    </div>
  </div>

  <div class="social-proof__ugc">
    {%- assign ugc_accents = '#F4A300,#EC4899,#7C3AED,#991B1B' | split: ',' -%}
    {%- for i in (1..4) -%}
      {%- assign ugc_key = 'ugc_image_' | append: i -%}
      {%- assign ugc_img = section.settings[ugc_key] -%}
      {%- assign ugc_accent = ugc_accents[forloop.index0] -%}
      <div class="social-proof__ugc-item">
        {%- if ugc_img != blank -%}
          {{ ugc_img | image_url: width: 200 | image_tag: loading: 'lazy', alt: '' }}
        {%- else -%}
          <div
            class="social-proof__ugc-placeholder"
            style="background: repeating-linear-gradient(135deg, {{ ugc_accent }}26, {{ ugc_accent }}26 5px, {{ ugc_accent }}0d 5px, {{ ugc_accent }}0d 10px); border: 1px dashed {{ ugc_accent }}70;"
            aria-hidden="true"
          ></div>
        {%- endif -%}
      </div>
    {%- endfor -%}
  </div>

</div>

{% stylesheet %}
  .social-proof {
    padding: 16px 0 6px;
  }
  .social-proof__heading {
    font-family: var(--font-display);
    font-size: 16px;
    font-weight: 800;
    line-height: 1;
    color: var(--color-ink);
    margin: 0 0 12px;
  }
  .social-proof__star {
    color: var(--color-sun);
  }
  .social-proof__bubble {
    position: relative;
    background: var(--color-mist);
    border-radius: 16px;
    padding: 16px;
    margin-bottom: 18px;
  }
  .social-proof__quote {
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 500;
    line-height: 1.55;
    color: var(--color-ink);
    margin: 0;
  }
  .social-proof__tail {
    position: absolute;
    bottom: -9px;
    left: 26px;
    width: 18px;
    height: 18px;
    background: var(--color-mist);
    transform: rotate(45deg);
  }
  .social-proof__reviewer {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 14px;
  }
  .social-proof__avatar {
    width: 34px;
    height: 34px;
    border-radius: 50%;
    flex: 0 0 auto;
    background: repeating-linear-gradient(135deg, #7C3AED33, #7C3AED33 6px, #7C3AED0d 6px, #7C3AED0d 12px);
    border: 1px dashed #7C3AED70;
  }
  .social-proof__name {
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 700;
    line-height: 1.1;
    color: var(--color-ink);
    margin: 0;
  }
  .social-proof__stars {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 600;
    line-height: 1;
    color: var(--color-sun);
    margin: 4px 0 0;
  }
  .social-proof__ugc {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr 1fr;
    gap: 8px;
  }
  .social-proof__ugc-item {
    border-radius: 10px;
    overflow: hidden;
    height: 68px;
  }
  .social-proof__ugc-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .social-proof__ugc-placeholder {
    width: 100%;
    height: 100%;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.social_proof",
  "settings": [
    {
      "type": "text",
      "id": "rating_summary",
      "label": "t:labels.rating_summary",
      "default": "4.9 from 300+ verified reviews"
    },
    {
      "type": "textarea",
      "id": "review_text",
      "label": "t:labels.review_text",
      "default": "Genuinely the only smell-proof bag I'd leave out on a shelf. The art's unreal and the seal actually works."
    },
    {
      "type": "text",
      "id": "reviewer_name",
      "label": "t:labels.reviewer_name",
      "default": "Maya R. · Verified buyer"
    },
    {
      "type": "header",
      "content": "t:general.ugc_photos"
    },
    {
      "type": "image_picker",
      "id": "ugc_image_1",
      "label": "t:labels.ugc_image_1"
    },
    {
      "type": "image_picker",
      "id": "ugc_image_2",
      "label": "t:labels.ugc_image_2"
    },
    {
      "type": "image_picker",
      "id": "ugc_image_3",
      "label": "t:labels.ugc_image_3"
    },
    {
      "type": "image_picker",
      "id": "ugc_image_4",
      "label": "t:labels.ugc_image_4"
    }
  ],
  "presets": [
    {
      "name": "t:general.social_proof"
    }
  ]
}
{% endschema %}
