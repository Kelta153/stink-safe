      "default": "Premium smell-proof storage — collectible art, built to last."
    },
    {
      "type": "header",
      "content": "t:general.navigation"
    },
    {
      "type": "text",
      "id": "shop_heading",
      "label": "t:labels.shop_heading",
      "default": "Shop"
    },
    {
      "type": "link_list",
      "id": "shop_menu",
      "label": "t:labels.shop_menu"
    },
    {
      "type": "text",
      "id": "help_heading",
      "label": "t:labels.help_heading",
      "default": "Help"
    },
    {
      "type": "link_list",
      "id": "help_menu",
      "label": "t:labels.help_menu"
    },
    {
      "type": "text",
      "id": "company_heading",
      "label": "t:labels.company_heading",
      "default": "Company"
    },
    {
      "type": "link_list",
      "id": "company_menu",
      "label": "t:labels.company_menu"
    },
    {
      "type": "header",
      "content": "t:general.social"
    },
    {
      "type": "url",
      "id": "instagram_url",
      "label": "t:labels.instagram_url"
    },
    {
      "type": "url",
      "id": "tiktok_url",
      "label": "t:labels.tiktok_url"
    },
    {
      "type": "url",
      "id": "telegram_url",
      "label": "t:labels.telegram_url"
    },
    {
      "type": "header",
      "content": "t:general.payment_legal"
    },
    {
      "type": "checkbox",
      "id": "show_payment_icons",
      "label": "t:labels.show_payment_icons",
      "default": true
    },
    {
      "type": "textarea",
      "id": "legal_text",
