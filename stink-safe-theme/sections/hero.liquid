{%- liquid
  assign cta_primary_url = section.settings.cta_primary_url | default: routes.collections_url
  assign cta_secondary_url = section.settings.cta_secondary_url | default: '/pages/bundles'
  assign hero_alt = section.settings.headline_line1 | default: 'Stink Safe'
-%}

<div class="hero full-width">
  <div class="hero__dots" aria-hidden="true"></div>

  <div class="hero__inner">

    <div class="hero__left">
      {%- if section.settings.eyebrow_label != blank -%}
        <p class="hero__eyebrow">{{- section.settings.eyebrow_label | escape -}}</p>
      {%- endif -%}

      <h1 class="hero__headline">
        {{- section.settings.headline_line1 | default: 'Art You Love.' | escape -}}<br>
        {{- section.settings.headline_line2 | default: "Smell You Don't." | escape -}}
      </h1>

      <svg class="hero__squiggle" viewBox="0 0 200 18" fill="none" stroke="#29791E" stroke-width="4" stroke-linecap="round" aria-hidden="true">
        <path d="M4 11c18-11 36 7 56 3s38-12 58-6 38 10 78 2"/>
      </svg>

      <p class="hero__subcopy">
        {{- section.settings.subheading | default: 'Odour-resistant storage with collector-grade comic art — built for travel, kitchen, gym bag and everywhere in between.' | escape -}}
      </p>

      <div class="hero__ctas">
        <a href="{{ cta_primary_url }}" class="hero__btn hero__btn--primary">
          {{- section.settings.cta_primary_text | default: 'Shop all' | escape -}}
        </a>
        <a href="{{ cta_secondary_url }}" class="hero__btn hero__btn--secondary">
          {{- section.settings.cta_secondary_text | default: 'Explore bundles' | escape -}}
        </a>
      </div>

      <p class="hero__trust">
        {{- section.settings.trust_line | default: 'Plain, unbranded parcels · Fast UK dispatch · Secure checkout' | escape -}}
      </p>
    </div>

    <div class="hero__imgrid">
      <div class="hero__imgrid-main">
        {%- if section.settings.hero_image_main != blank -%}
          {{ section.settings.hero_image_main | image_url: width: 600 | image_tag: loading: 'eager', fetchpriority: 'high', alt: hero_alt }}
        {%- else -%}
          <div class="hero__ph" style="background: repeating-linear-gradient(135deg, #F4A30026, #F4A30026 7px, #F4A3000d 7px, #F4A3000d 14px); border: 1px dashed #F4A30070;">
            <span style="color: #F4A300">Crimewave &middot; hero pack</span>
          </div>
        {%- endif -%}
      </div>

      <div class="hero__imgrid-pack">
        {%- if section.settings.hero_image_pack != blank -%}
          {{ section.settings.hero_image_pack | image_url: width: 400 | image_tag: loading: 'eager', alt: '' }}
        {%- else -%}
          <div class="hero__ph" style="background: repeating-linear-gradient(135deg, #EC489926, #EC489926 7px, #EC48990d 7px, #EC48990d 14px); border: 1px dashed #EC489970;">
            <span style="color: #EC4899">Snackverse pack</span>
          </div>
        {%- endif -%}
      </div>

      <div class="hero__imgrid-life">
        {%- if section.settings.hero_image_lifestyle != blank -%}
          {{ section.settings.hero_image_lifestyle | image_url: width: 400 | image_tag: loading: 'lazy', alt: '' }}
        {%- else -%}
          <div class="hero__ph" style="background: repeating-linear-gradient(135deg, #2463EB26, #2463EB26 7px, #2463EB0d 7px, #2463EB0d 14px); border: 1px dashed #2463EB70;">
            <span style="color: #2463EB">Lifestyle &middot; travel</span>
          </div>
        {%- endif -%}
      </div>
    </div>

  </div>
</div>

{% stylesheet %}
  .hero {
    position: relative;
    overflow: hidden;
    background: var(--color-mist);
    border-radius: 0 0 26px 26px;
  }

  .hero__dots {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(rgba(36, 99, 235, 0.09) 1.5px, transparent 1.7px);
    background-size: 18px 18px;
    pointer-events: none;
  }

  .hero__inner {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 20px;
    padding: 28px var(--page-gutter) 32px;
  }

  .hero__eyebrow {
    font-family: var(--font-label);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-blue);
    margin: 0;
  }

  .hero__headline {
    font-family: var(--font-display);
    font-size: 36px;
    line-height: 1.02;
    font-weight: 800;
    color: var(--color-ink);
    letter-spacing: -0.025em;
    margin: 14px 0 0;
  }

  .hero__squiggle {
    width: 200px;
    height: 16px;
    margin-top: 10px;
    display: block;
    flex-shrink: 0;
  }

  .hero__subcopy {
    font-family: var(--font-body);
    font-size: 14px;
    line-height: 1.6;
    font-weight: 400;
    color: var(--color-slate);
    margin: 16px 0 0;
  }

  .hero__ctas {
    display: flex;
    gap: 12px;
    margin-top: 24px;
    flex-wrap: wrap;
  }

  .hero__btn {
    border-radius: 13px;
    padding: 15px 24px;
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 700;
    text-align: center;
    text-decoration: none;
    display: inline-block;
    line-height: 1;
    box-sizing: border-box;
    white-space: nowrap;
  }

  .hero__btn--primary {
    background: var(--color-blue);
    color: var(--color-white);
    box-shadow: 0 12px 26px rgba(36, 99, 235, 0.30);
  }

  .hero__btn--secondary {
    background: var(--color-white);
    color: var(--color-blue);
    border: 1.5px solid var(--color-blue);
  }

  .hero__trust {
    font-family: var(--font-body);
    font-size: 12.5px;
    font-weight: 600;
    color: var(--color-slate);
    margin-top: 18px;
    line-height: 1.4;
  }

  /* 2×2 image grid — left col spans both rows */
  .hero__imgrid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: 95px 95px;
    gap: 10px;
  }

  .hero__imgrid-main {
    grid-row: span 2;
    border-radius: 14px;
    overflow: hidden;
  }

  .hero__imgrid-pack,
  .hero__imgrid-life {
    border-radius: 14px;
    overflow: hidden;
  }

  .hero__imgrid-main img,
  .hero__imgrid-pack img,
  .hero__imgrid-life img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .hero__ph {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 8px;
    box-sizing: border-box;
    text-align: center;
  }

  .hero__ph span {
    font-family: var(--font-label);
    font-size: 9px;
    font-weight: 700;
    text-transform: uppercase;
    line-height: 1.3;
  }

  @media (min-width: 768px) {
    .hero {
      border-radius: 0 0 32px 32px;
    }

    .hero__inner {
      flex-direction: row;
      align-items: center;
      gap: 56px;
      padding: 64px 40px 72px;
      max-width: 1200px;
      margin: 0 auto;
    }

    .hero__left {
      flex: 0 0 51.5%;
    }

    .hero__headline {
      font-size: 64px;
      margin-top: 18px;
    }

    .hero__squiggle {
      width: 300px;
      height: 22px;
      margin-top: 12px;
    }

    .hero__subcopy {
      font-size: 18px;
      margin-top: 22px;
    }

    .hero__ctas {
      margin-top: 32px;
    }

    .hero__btn {
      font-size: 16px;
      padding: 17px 30px;
    }

    .hero__trust {
      margin-top: 24px;
      font-size: 13px;
    }

    .hero__imgrid {
      flex: 1;
      min-width: 0;
      grid-template-rows: 163px 163px;
      gap: 14px;
    }

    .hero__imgrid-main,
    .hero__imgrid-pack,
    .hero__imgrid-life {
      border-radius: 18px;
    }

    .hero__ph span {
      font-size: 11px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.hero",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow_label",
      "label": "t:labels.eyebrow_label",
      "default": "Drop No. 001 — Limited Series"
    },
    {
      "type": "text",
      "id": "headline_line1",
      "label": "t:labels.headline_line1",
      "default": "Art You Love."
    },
    {
      "type": "text",
      "id": "headline_line2",
      "label": "t:labels.headline_line2",
      "default": "Smell You Don't."
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "t:labels.subheading",
      "default": "Odour-resistant storage with collector-grade comic art — built for travel, kitchen, gym bag and everywhere in between."
    },
    {
      "type": "header",
      "content": "t:general.hero_images"
    },
    {
      "type": "image_picker",
      "id": "hero_image_main",
      "label": "t:labels.hero_image_main"
    },
    {
      "type": "image_picker",
      "id": "hero_image_pack",
      "label": "t:labels.hero_image_pack"
    },
    {
      "type": "image_picker",
      "id": "hero_image_lifestyle",
      "label": "t:labels.hero_image_lifestyle"
    },
    {
      "type": "header",
      "content": "t:general.navigation"
    },
    {
      "type": "text",
      "id": "cta_primary_text",
      "label": "t:labels.cta_primary_text",
      "default": "Shop all"
    },
    {
      "type": "url",
      "id": "cta_primary_url",
      "label": "t:labels.cta_primary_url"
    },
    {
      "type": "text",
      "id": "cta_secondary_text",
      "label": "t:labels.cta_secondary_text",
      "default": "Explore bundles"
    },
    {
      "type": "url",
      "id": "cta_secondary_url",
      "label": "t:labels.cta_secondary_url"
    },
    {
      "type": "text",
      "id": "trust_line",
      "label": "t:labels.trust_line",
      "default": "Plain, unbranded parcels · Fast UK dispatch · Secure checkout"
    }
  ],
  "presets": [
    {
      "name": "t:general.hero"
    }
  ]
}
{% endschema %}
